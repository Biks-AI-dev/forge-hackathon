DAYTONA_API_KEY=
DAYTONA_BASE_URL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
NOSANA_API_KEY=
NOSANA_WHISPER_URL=
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
OXYLABS_SCRAPER_URL=

# ============== notula (AI meeting scribe) ==============
# ===== LLM (Kimi) =====
# OpenAI-compatible endpoint. Two common setups:
#   1. Nosana GPU deployment running Kimi -> your Nosana inference URL, e.g.
#      KIMI_BASE_URL=https://<your-nosana-endpoint>/v1
#   2. Moonshot's hosted API (fallback / development):
#      KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_API_KEY=
# Model name as exposed by the endpoint (Nosana deployments often expose the
# exact HF model id; Moonshot uses e.g. kimi-k2-0711-preview / moonshot-v1-8k)
KIMI_MODEL=kimi-k2-0711-preview

# ===== Daytona (live prototype sandbox) =====
# Get from https://app.daytona.io -> API Keys. Leave empty to preview the
# generated UI locally at /preview instead of in a Daytona sandbox.
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

PORT=4100

# Heavier model for PRD + UI generation (notes keep using KIMI_MODEL).
KIMI_SMART_MODEL=

# Whisper ASR on your Nosana GPU deployment (whisper-asr-webservice, port 9000).
# When set, recording uses real audio -> Whisper instead of browser Web Speech.
NOSANA_WHISPER_URL=

# Fast non-thinking model for UI generation (PRD keeps KIMI_SMART_MODEL).
KIMI_UI_MODEL=
